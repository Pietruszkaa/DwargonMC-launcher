# Absolute path to the checked-out/deployed project directory.
# Dockage users usually want this to point at the folder containing sync-server/ and admin-site/.
DWARGONMC_ROOT=/opt/dwargonmc

# Public sync backend URL used in generated links and launcher settings.
PUBLIC_URL=https://sync.example.com

# Sync server binding.
SYNC_PORT=2121
SYNC_BIND_HOST=0.0.0.0

# Minecraft server health target.
MC_HOST=127.0.0.1
MC_PORT=25565
MC_ADDRESS=
MC_VERSION=1.21.1
MC_LOADER=neoforge
MC_LOADER_VERSION=latest

# Optional server password for future launcher-side verification.
SERVER_PASSWORD=

# Map upstream. With network_mode: host this may point at a local service.
MAP_TARGET=http://127.0.0.1:8888

# Optional for admin-site write operations. Empty means no admin token required.
ADMIN_TOKEN=

# Optional headers for protected map upstreams.
MAP_ACCESS_CLIENT_ID=
MAP_ACCESS_CLIENT_SECRET=
MAP_REQUEST_HEADERS=
