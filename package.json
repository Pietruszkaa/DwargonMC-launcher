{
  "name": "dwargonmc",
  "version": "1.1.2",
  "private": true,
  "description": "DwargonMC launcher monorepo.",
  "scripts": {
    "launcher:dev": "npm --prefix launcher run dev",
    "launcher:dev:electron": "npm --prefix launcher run dev:electron",
    "launcher:clean-dev-data": "npm --prefix launcher run clean:dev-data",
    "launcher:typecheck": "npm --prefix launcher run typecheck",
    "launcher:test": "npm --prefix launcher test",
    "launcher:build": "npm --prefix launcher run build",
    "launcher:dist:win": "npm --prefix launcher run dist:win",
    "sync:start": "npm --prefix sync-server start",
    "sync:manifest": "npm --prefix sync-server run manifest"
  },
  "workspaces": [
    "launcher",
    "sync-server"
  ]
}
