{
  "name": "dwargon-launcher",
  "version": "3.0.0",
  "private": true,
  "description": "Portable multi-instance Minecraft launcher.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "node scripts/dev-electron.cjs",
    "ensure:electron": "node scripts/ensure-electron.cjs",
    "clean:dev-data": "node scripts/clean-dev-data.cjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.electron.json && tsc --noEmit && vite build",
    "postinstall": "node scripts/ensure-electron.cjs",
    "dist:win": "npm run build && node scripts/patch-request-form-data.cjs && electron-builder --win dir portable --publish never",
    "dist:linux": "npm run build && electron-builder --linux dir tar.gz"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "form-data": "^4.0.5",
    "keytar": "^7.9.0",
    "minecraft-launcher-core": "^3.18.1",
    "msmc": "^5.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "42.3.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "pl.dwargon.launcher",
    "productName": "Dwargon Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "assets/backgrounds/1.png",
      "assets/icon.ico",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-portable.${ext}",
      "target": [
        "dir",
        "portable"
      ]
    },
    "linux": {
      "icon": "assets/logo.png",
      "category": "Game",
      "artifactName": "${productName}-${version}-linux.${ext}",
      "target": [
        "dir",
        "tar.gz"
      ]
    }
  },
  "overrides": {
    "request": {
      "form-data": "2.5.5"
    }
  }
}
